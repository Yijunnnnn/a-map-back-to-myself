# Gemini API Key and Model configuration
GEMINI_API_KEY="your-api-key-here"
GEMINI_MODEL="gemini-3.5-flash"

# SelfMap Agent configuration
SELFMAP_MODE=demo  # or production
USE_DEMO_SEED=true  # set to false to start clean
ACTIVE_PROFILE_ID=demo_user  # identifier for scoping data and log storage

